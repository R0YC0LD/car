rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Vehicles (Filo) koleksiyonu kuralları
    match /vehicles/{vehicleId} {
      allow read, write: if true;
    }
    
    // Reservations (Rezervasyonlar) koleksiyonu kuralları
    match /reservations/{reservationId} {
      allow read, write: if true;
    }

    // Testimonials (Müşteri Yorumları) koleksiyonu kuralları
    match /testimonials/{reviewId} {
      allow read, write: if true;
    }

    // FAQs (Sıkça Sorulan Sorular) koleksiyonu kuralları
    match /faqs/{faqId} {
      allow read, write: if true;
    }

    // Varsayılan kural
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
